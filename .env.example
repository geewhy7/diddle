# Telegram bot token that owns the Mini App (required).
TELEGRAM_TOKEN=123456789:your-bot-token-here

# Public HTTPS origin the Mini App is served from (used for t.me deep links
# and CORS). For local development behind a tunnel, set both to that URL.
GAME_URL=https://your-domain.example
CORS_ORIGIN=https://your-domain.example

# SQLite database path.
DB_PATH=diddle.db

# Skip Telegram initData HMAC verification — LOCAL DEV ONLY. Never set in prod.
DEV_SKIP_AUTH=false

# --- Puzzle tuning (all optional; sensible defaults in code) ---
# Daily puzzle difficulty (ladder length range) and the era-reset seed lever.
PUZZLE_MIN_STEPS=4
PUZZLE_MAX_STEPS=7
PUZZLE_SEED_OFFSET=0

# Hard Mode difficulty range.
CHALLENGE_MIN_STEPS=9
CHALLENGE_MAX_STEPS=15

# Under-par guards: reseed a day's puzzle until the true optimum (over the full
# typeable word set) is within this many steps of the displayed par.
PUZZLE_MAX_UNDER=1
CHALLENGE_MAX_UNDER=2

# Per-guess shot clock in seconds (0 disables the timer).
GUESS_TIME_LIMIT=20
